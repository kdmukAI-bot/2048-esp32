# Board: Waveshare ESP32-P4 WiFi6 Touch LCD 3.5
# SoC-specific settings (flash, PSRAM, CPU)

# Flash: 16MB QIO @ 80MHz
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# PSRAM: 32MB @ 200MHz (P4 supports higher PSRAM speeds)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MEMTEST=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=n

# Performance: 400 MHz CPU + -O2 optimization
CONFIG_COMPILER_OPTIMIZATION_PERF=y
